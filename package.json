{
  "name": "zoia-emulator",
  "version": "0.1.0",
  "private": true,
  "description": "ZOIA emulator source, shared SSL support package, and deterministic parser/Playwright/audio test harness.",
  "scripts": {
    "start": "npm run zoia:serve",
    "zoia:serve": "node tools/serve-zoia.mjs",
    "zoia:lint:no-magic": "npm --prefix tests/parser-harness run zoia:lint:no-magic",
    "zoia:fixtures:all": "npm --prefix tests/parser-harness run zoia:fixtures:all",
    "zoia:patch-library:prepare": "powershell -NoProfile -ExecutionPolicy Bypass -File tests/workflow/scripts/prepare-zoia-patch-library-cache.ps1",
    "zoia:test:parser": "npm run zoia:lint:no-magic && npm run zoia:fixtures:all",
    "zoia:test:playwright": "node tests/workflow/playwright/run-zoia-playwright-evidence.mjs",
    "zoia:test:playwright:interactions": "node tests/workflow/playwright/run-zoia-playwright-interaction-evidence.mjs",
    "zoia:test:playwright:controls": "node tests/workflow/playwright/run-zoia-playwright-controls-evidence.mjs",
    "zoia:test:playwright:broad": "node tests/workflow/playwright/run-zoia-playwright-broad-rebaseline-evidence.mjs",
    "zoia:test:playwright:all-patches": "node tests/workflow/playwright/run-zoia-playwright-all-patches-evidence.mjs",
    "zoia:test:playwright:staged-deep": "node tests/workflow/playwright/run-zoia-playwright-staged-deep-evidence.mjs",
    "zoia:test:playwright:patch-library-full": "node tests/workflow/playwright/run-zoia-playwright-library-and-verification-patches-evidence.mjs",
    "zoia:test:playwright:library-deep": "node tests/workflow/playwright/run-zoia-playwright-library-deep-evidence.mjs",
    "zoia:test:playwright:audio-provenance": "node tests/workflow/playwright/run-zoia-playwright-audio-provenance-evidence.mjs",
    "zoia:test:playwright:audio-fixtures": "node tests/workflow/playwright/run-zoia-playwright-audio-fixtures-evidence.mjs",
    "zoia:test:playwright:audio-delay-tone": "node tests/workflow/playwright/run-zoia-playwright-audio-delay-tone-evidence.mjs",
    "zoia:test:playwright:staged-patch-audio": "node tests/workflow/playwright/run-zoia-playwright-staged-patch-audio-evidence.mjs",
    "zoia:test:playwright:community-audio": "node tests/workflow/playwright/run-zoia-playwright-community-audio-evidence.mjs",
    "zoia:test:evidence": "npm run zoia:test:parser && npm run zoia:test:playwright && npm run zoia:test:playwright:interactions && npm run zoia:test:playwright:controls && npm run zoia:test:playwright:broad",
    "zoia:test:evidence:full": "npm run zoia:test:evidence && npm run zoia:test:playwright:all-patches",
    "zoia:test:evidence:library-full": "npm run zoia:patch-library:prepare && npm run zoia:test:evidence && npm run zoia:test:playwright:patch-library-full",
    "test": "npm run zoia:test:ci",
    "zoia:ssl:proof": "node tests/workflow/scripts/generate-ssl-rebaseline-proof.mjs",
    "zoia:test:ci": "node tests/workflow/scripts/run-zoia-ci-gates.mjs",
    "zoia:github:boundary": "node tests/workflow/scripts/generate-github-readiness-boundary.mjs",
    "zoia:test:publication": "npm run zoia:test:ci && npm run zoia:patch-library:prepare && npm run zoia:test:playwright:community-audio"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  },
  "dependencies": {
    "@zoia/shared-ssl": "file:shared/ssl/zoia-shared-ssl"
  }
}
