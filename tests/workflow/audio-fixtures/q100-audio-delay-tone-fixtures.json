    },
    {
      "area": "Noise audio module",
      "reason": "The Noise factory fills buffers with Math.random. Deterministic coverage requires seeded noise buffers with recorded seed, algorithm, sample rate, and hash provenance."
    },
    {
      "area": "Reverb impulse-response classes",
      "reason": "The Reverb, Plate Reverb, Hall Reverb, Shimmer/Ghostverb, Reverse Reverb, and related classes build impulse responses with Math.random and/or modulation. Deterministic coverage requires seeded impulse-response generation or checked-in fixture IR hashes."
    },
    {
      "area": "time-polling modules",
      "reason": "Some factories use requestAnimationFrame polling for CV/control behavior. These require offline-safe polling or direct automation before deterministic audio assertions."
    },
    {
      "area": "full community patch audio",
      "reason": "Full patch audio requires deterministic input stimuli and expected audio feature baselines per patch."
    }
